# .gitignore

# Environment Variables — NEVER commit real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Keep the example file (with placeholders only)
!.env.example

# ──────────────────────────────────────────────────────────────────────────────
# Node.js / JavaScript / TypeScript
# ──────────────────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.next/
.nuxt/
.output/
out/
coverage/
*.tsbuildinfo
.turbo/
.eslintcache
.parcel-cache/
.cache/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
.venv/
venv/
env/
.eggs/
*.egg-info/
dist/
*.dist-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ──────────────────────────────────────────────────────────────────────────────
# Java / Kotlin / Gradle / Maven
# ──────────────────────────────────────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
.gradle/
build/
out/
*.iml
.classpath
.project
.settings/

# ──────────────────────────────────────────────────────────────────────────────
# .NET / C#
# ──────────────────────────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
*.userprefs
.vs/
TestResults/
*.nupkg
*.snupkg

# ──────────────────────────────────────────────────────────────────────────────
# Go
# ──────────────────────────────────────────────────────────────────────────────
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
# Test binary, built with `go test -c`
*.test
# Output of `go build`
/go-binary

# ──────────────────────────────────────────────────────────────────────────────
# Secrets and Certificates
# ──────────────────────────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
secrets/
credentials/
.secrets/

# ──────────────────────────────────────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────────────────────────────────────
.docker/data/

# ──────────────────────────────────────────────────────────────────────────────
# Terraform / Infrastructure
# ──────────────────────────────────────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
!example.tfvars
.terraform/
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ──────────────────────────────────────────────────────────────────────────────
# IDEs and Editors
# ──────────────────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
*.swn
*~
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# Keep shared VS Code settings (extensions, tasks)
!.vscode/extensions.json
!.vscode/tasks.json

# ──────────────────────────────────────────────────────────────────────────────
# OS Generated Files
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────────────────────────────────────
# Miscellaneous
# ──────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.swp
```
